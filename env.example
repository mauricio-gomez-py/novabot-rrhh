# ============================================================
#  NovaBot — Variables de Configuración
#  Copia este archivo como .env y completa los valores reales
#  NUNCA subas el archivo .env a GitHub
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Obtén tu token creando un bot con @BotFather en Telegram

# --- OpenAI ---
OPENAI_API_KEY=sk-your_openai_api_key_here
# Modelo usado: gpt-4o-mini | Embeddings: text-embedding-3-small

# --- Google Sheets ---
GOOGLE_SHEET_ID=your_google_sheet_id_here
# El ID está en la URL de tu Sheet:
# https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit

# Hojas requeridas dentro del documento:
# - "Registro Conversaciones"  → logging de interacciones
# - "Empleados"                → base de datos de empleados
# - "Solicitudes_Vacaciones"   → registro de solicitudes

# --- Google Calendar ---
GOOGLE_CALENDAR_ID=your_calendar_id_here
# Normalmente es tu email de Google: usuario@gmail.com

# --- Webhook Lovable ---
LOVABLE_ALLOWED_ORIGIN=https://your-app.lovable.app
# Reemplaza el wildcard (*) por el dominio real de tu app Lovable

# --- n8n ---
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/novabot
# URL base de tu instancia n8n (local o en la nube)
